<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFDF7">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="130dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:paddingBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="245dp"
                android:background="#306D29"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingTop="52dp"
                android:paddingEnd="20dp"
                android:paddingBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="24dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/plus_jakarta_sans_medium"
                        android:text="Total Pengeluaran"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp" />

                    <LinearLayout
                        android:id="@+id/chipPengeluaranMonth"
                        android:layout_width="wrap_content"
                        android:layout_height="22dp"
                        android:background="@drawable/pengeluaran_month_chip_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:paddingStart="8dp"
                        android:paddingEnd="7dp">

                        <TextView
                            android:id="@+id/tvPengeluaranMonth"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:fontFamily="@font/plus_jakarta_sans_medium"
                            android:gravity="center"
                            android:text="Juni 2026"
                            android:textColor="#306D29"
                            android:textSize="10sp" />

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_marginStart="5dp"
                            android:contentDescription="@null"
                            android:scaleType="centerInside"
                            android:src="@drawable/ic_calendar_input" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvTotalPengeluaran"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/roboto_bold"
                    android:text="Rp 0"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="224dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="-108dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/pengeluaran_chart_card_bg"
                android:elevation="3dp"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:fontFamily="@font/plus_jakarta_sans_medium"
                    android:text="Avg 6 bulan terakhir Rp1,5Jt"
                    android:textColor="#FFA43C"
                    android:textSize="10sp"
                    android:visibility="gone" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="8dp"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="42dp"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:fontFamily="@font/plus_jakarta_sans_regular"
                            android:gravity="center_vertical|end"
                            android:text="2,5Jt"
                            android:textColor="#8A8F83"
                            android:textSize="8sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:fontFamily="@font/plus_jakarta_sans_regular"
                            android:gravity="center_vertical|end"
                            android:text="2Jt"
                            android:textColor="#8A8F83"
                            android:textSize="8sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:fontFamily="@font/plus_jakarta_sans_regular"
                            android:gravity="center_vertical|end"
                            android:text="1,5Jt"
                            android:textColor="#8A8F83"
                            android:textSize="8sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:fontFamily="@font/plus_jakarta_sans_regular"
                            android:gravity="center_vertical|end"
                            android:text="1Jt"
                            android:textColor="#8A8F83"
                            android:textSize="8sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:fontFamily="@font/plus_jakarta_sans_regular"
                            android:gravity="center_vertical|end"
                            android:text="500rb"
                            android:textColor="#8A8F83"
                            android:textSize="8sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:fontFamily="@font/plus_jakarta_sans_regular"
                            android:gravity="center_vertical|end"
                            android:text="0rb"
                            android:textColor="#8A8F83"
                            android:textSize="8sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1">

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:layout_marginTop="8dp"
                                android:background="#EDEDE8" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:layout_marginTop="32dp"
                                android:background="#EDEDE8" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:layout_marginTop="56dp"
                                android:background="#EDEDE8" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:layout_marginTop="80dp"
                                android:background="#EDEDE8" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:layout_marginTop="104dp"
                                android:background="#EDEDE8" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="2dp"
                                android:layout_marginTop="54dp"
                                android:background="#FFA43C" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="bottom"
                                android:orientation="horizontal">

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="1"
                                    android:gravity="bottom|center_horizontal">

                                    <View
                                        android:layout_width="14dp"
                                        android:layout_height="58dp"
                                        android:background="@drawable/pengeluaran_bar_inactive_bg" />
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="1"
                                    android:gravity="bottom|center_horizontal">

                                    <View
                                        android:layout_width="14dp"
                                        android:layout_height="74dp"
                                        android:background="@drawable/pengeluaran_bar_inactive_bg" />
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="1"
                                    android:gravity="bottom|center_horizontal">

                                    <View
                                        android:layout_width="14dp"
                                        android:layout_height="48dp"
                                        android:background="@drawable/pengeluaran_bar_inactive_bg" />
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="1"
                                    android:gravity="bottom|center_horizontal">

                                    <View
                                        android:layout_width="14dp"
                                        android:layout_height="88dp"
                                        android:background="@drawable/pengeluaran_bar_inactive_bg" />
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="1"
                                    android:gravity="bottom|center_horizontal">

                                    <View
                                        android:layout_width="14dp"
                                        android:layout_height="66dp"
                                        android:background="@drawable/pengeluaran_bar_inactive_bg" />
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="1"
                                    android:gravity="bottom|center_horizontal">

                                    <View
                                        android:layout_width="14dp"
                                        android:layout_height="112dp"
                                        android:background="@drawable/pengeluaran_bar_active_bg" />
                                </LinearLayout>
                            </LinearLayout>
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="24dp"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:fontFamily="@font/plus_jakarta_sans_regular"
                                android:gravity="center"
                                android:text="Jan 26"
                                android:textColor="#8A8F83"
                                android:textSize="8sp" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:fontFamily="@font/plus_jakarta_sans_regular"
                                android:gravity="center"
                                android:text="Feb 26"
                                android:textColor="#8A8F83"
                                android:textSize="8sp" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:fontFamily="@font/plus_jakarta_sans_regular"
                                android:gravity="center"
                                android:text="Mar 26"
                                android:textColor="#8A8F83"
                                android:textSize="8sp" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:fontFamily="@font/plus_jakarta_sans_regular"
                                android:gravity="center"
                                android:text="Apr 26"
                                android:textColor="#8A8F83"
                                android:textSize="8sp" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:fontFamily="@font/plus_jakarta_sans_regular"
                                android:gravity="center"
                                android:text="Mei 26"
                                android:textColor="#8A8F83"
                                android:textSize="8sp" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:fontFamily="@font/plus_jakarta_sans_regular"
                                android:gravity="center"
                                android:text="Jun 26"
                                android:textColor="#306D29"
                                android:textSize="8sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <com.java.kalkulatorkeuangan.ExpenseBarChartView
                    android:id="@+id/expenseBarChart"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="14dp"
                android:fontFamily="@font/plus_jakarta_sans_semibold"
                android:text="Rincian Kategori"
                android:textColor="#262A24"
                android:textSize="20sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/containerKategori"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:orientation="vertical">
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/customBottomNav"
        android:layout_width="match_parent"
        android:layout_height="74dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_bottom_nav"
        android:elevation="8dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingTop="8dp"
        android:paddingEnd="10dp"
        android:paddingBottom="6dp">

        <LinearLayout
            android:id="@+id/navHomeButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_home_inactive"
                android:scaleType="centerInside"
                android:adjustViewBounds="false" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:fontFamily="@font/plus_jakarta_sans_regular"
                android:gravity="center"
                android:textAlignment="center"
                android:includeFontPadding="false"
                android:minHeight="12dp"
                android:singleLine="true"
                android:text="Beranda"
                android:textColor="#262A24"
                android:textSize="9sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navPengeluaranButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.15"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_expenditure_active"
                android:scaleType="centerInside"
                android:adjustViewBounds="false" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:fontFamily="@font/plus_jakarta_sans_regular"
                android:gravity="center"
                android:textAlignment="center"
                android:includeFontPadding="false"
                android:minHeight="12dp"
                android:singleLine="true"
                android:text="Pengeluaran"
                android:textColor="#306D29"
                android:textSize="9sp" />
        </LinearLayout>

        <Space
            android:layout_width="74dp"
            android:layout_height="1dp" />

        <LinearLayout
            android:id="@+id/navBudgetButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_budget_inactive"
                android:scaleType="centerInside"
                android:adjustViewBounds="false" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:fontFamily="@font/plus_jakarta_sans_regular"
                android:gravity="center"
                android:textAlignment="center"
                android:includeFontPadding="false"
                android:minHeight="12dp"
                android:singleLine="true"
                android:text="Budget"
                android:textColor="#262A24"
                android:textSize="9sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navRiwayatButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_history_inactive"
                android:scaleType="centerInside"
                android:adjustViewBounds="false" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:fontFamily="@font/plus_jakarta_sans_regular"
                android:gravity="center"
                android:textAlignment="center"
                android:includeFontPadding="false"
                android:minHeight="12dp"
                android:singleLine="true"
                android:text="Riwayat"
                android:textColor="#262A24"
                android:textSize="9sp" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/fabAdd"
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="9dp"
        android:clickable="true"
        android:elevation="16dp"
        android:focusable="true"
        android:foreground="@drawable/fab_center_oval_ripple"
        android:translationZ="16dp">

        <FrameLayout
            android:layout_width="66dp"
            android:layout_height="66dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_center_input_button">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:scaleType="centerInside"
                android:src="@drawable/ic_input" />
        </FrameLayout>
    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
