<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFDF7"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/riwayatScreenWrapper"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFDF7"
        android:clipChildren="true"
        android:clipToPadding="false"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="40dp"
        android:paddingEnd="16dp">

        <LinearLayout
            android:id="@+id/searchRiwayatContainer"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/riwayat_search_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="14dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@null"
                android:src="@android:drawable/ic_menu_search"
                android:tint="#8A8F83" />

            <EditText
                android:id="@+id/etSearchRiwayat"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:fontFamily="@font/plus_jakarta_sans_medium"
                android:hint="Cari transaksi..."
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:padding="0dp"
                android:singleLine="true"
                android:textColor="#262A24"
                android:textColorHint="#8A8F83"
                android:textSize="12sp" />
        </LinearLayout>

        <HorizontalScrollView
            android:id="@+id/riwayatChipScroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/riwayatChipContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="2dp">

                <TextView
                    android:id="@+id/chipSemua"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:background="@drawable/riwayat_chip_active_bg"
                    android:fontFamily="@font/plus_jakarta_sans_medium"
                    android:gravity="center"
                    android:minWidth="72dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="Semua"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/chipPemasukan"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/riwayat_chip_inactive_bg"
                    android:elevation="1dp"
                    android:fontFamily="@font/plus_jakarta_sans_medium"
                    android:gravity="center"
                    android:minWidth="72dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="Pemasukan"
                    android:textColor="#8A8F83"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/chipMakanan"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/riwayat_chip_inactive_bg"
                    android:elevation="1dp"
                    android:fontFamily="@font/plus_jakarta_sans_medium"
                    android:gravity="center"
                    android:minWidth="72dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="Makanan"
                    android:textColor="#8A8F83"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/chipCamilan"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/riwayat_chip_inactive_bg"
                    android:elevation="1dp"
                    android:fontFamily="@font/plus_jakarta_sans_medium"
                    android:gravity="center"
                    android:minWidth="72dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="Camilan"
                    android:textColor="#8A8F83"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/chipBelanja"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/riwayat_chip_inactive_bg"
                    android:elevation="1dp"
                    android:fontFamily="@font/plus_jakarta_sans_medium"
                    android:gravity="center"
                    android:minWidth="72dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="Belanja"
                    android:textColor="#8A8F83"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/chipTagihan"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/riwayat_chip_inactive_bg"
                    android:elevation="1dp"
                    android:fontFamily="@font/plus_jakarta_sans_medium"
                    android:gravity="center"
                    android:minWidth="72dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="Tagihan"
                    android:textColor="#8A8F83"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/chipKesehatan"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/riwayat_chip_inactive_bg"
                    android:elevation="1dp"
                    android:fontFamily="@font/plus_jakarta_sans_medium"
                    android:gravity="center"
                    android:minWidth="72dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="Kesehatan"
                    android:textColor="#8A8F83"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/chipEdukasi"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/riwayat_chip_inactive_bg"
                    android:elevation="1dp"
                    android:fontFamily="@font/plus_jakarta_sans_medium"
                    android:gravity="center"
                    android:minWidth="72dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="Edukasi"
                    android:textColor="#8A8F83"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/chipHiburan"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/riwayat_chip_inactive_bg"
                    android:elevation="1dp"
                    android:fontFamily="@font/plus_jakarta_sans_medium"
                    android:gravity="center"
                    android:minWidth="72dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="Hiburan"
                    android:textColor="#8A8F83"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/chipTabungan"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/riwayat_chip_inactive_bg"
                    android:elevation="1dp"
                    android:fontFamily="@font/plus_jakarta_sans_medium"
                    android:gravity="center"
                    android:minWidth="72dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="Tabungan"
                    android:textColor="#8A8F83"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/chipSewaKos"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/riwayat_chip_inactive_bg"
                    android:elevation="1dp"
                    android:fontFamily="@font/plus_jakarta_sans_medium"
                    android:gravity="center"
                    android:minWidth="72dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="Sewa Kos"
                    android:textColor="#8A8F83"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/chipLainnya"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="1dp"
                    android:background="@drawable/riwayat_chip_inactive_bg"
                    android:elevation="1dp"
                    android:fontFamily="@font/plus_jakarta_sans_medium"
                    android:gravity="center"
                    android:minWidth="72dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="Lainnya"
                    android:textColor="#8A8F83"
                    android:textSize="12sp" />
            </LinearLayout>
        </HorizontalScrollView>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvRiwayat"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="18dp"
            android:layout_weight="1"
            android:clipChildren="true"
            android:clipToPadding="false"
            android:paddingBottom="120dp" />

        <TextView
            android:id="@+id/tvRiwayatEmpty"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="18dp"
            android:layout_weight="1"
            android:fontFamily="@font/plus_jakarta_sans_medium"
            android:gravity="center"
            android:text="Transaksi tidak ditemukan"
            android:textColor="#8A8F83"
            android:textSize="12sp"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/customBottomNav"
        android:layout_width="match_parent"
        android:layout_height="74dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_bottom_nav"
        android:elevation="8dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingTop="8dp"
        android:paddingEnd="10dp"
        android:paddingBottom="6dp">

        <LinearLayout
            android:id="@+id/navHomeButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_home_inactive" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:fontFamily="@font/plus_jakarta_sans_regular"
                android:text="Beranda"
                android:textColor="#262A24"
                android:textSize="9sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navPengeluaranButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.15"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_expenditure_inactive" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:fontFamily="@font/plus_jakarta_sans_regular"
                android:singleLine="true"
                android:text="Pengeluaran"
                android:textColor="#262A24"
                android:textSize="8sp" />
        </LinearLayout>

        <Space
            android:layout_width="74dp"
            android:layout_height="1dp" />

        <LinearLayout
            android:id="@+id/navBudgetButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_budget_inactive" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:fontFamily="@font/plus_jakarta_sans_regular"
                android:text="Budget"
                android:textColor="#262A24"
                android:textSize="9sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navRiwayatButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_history_active" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:fontFamily="@font/plus_jakarta_sans_medium"
                android:text="Riwayat"
                android:textColor="#306D29"
                android:textSize="9sp" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/fabAdd"
        android:layout_width="66dp"
        android:layout_height="66dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_center_input_button"
        android:clickable="true"
        android:elevation="16dp"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackgroundBorderless"
        android:translationZ="16dp">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center"
            android:contentDescription="@null"
            android:scaleType="centerInside"
            android:src="@drawable/ic_input" />
    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
