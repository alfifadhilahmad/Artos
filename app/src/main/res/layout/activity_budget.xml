<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFDF7">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="112dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="245dp"
                android:background="#306D29"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingTop="52dp"
                android:paddingEnd="16dp"
                android:paddingBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/plus_jakarta_sans_medium"
                        android:text="Sisa Budget"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp" />

                    <LinearLayout
                        android:layout_width="64dp"
                        android:layout_height="44dp"
                        android:gravity="end"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvBudgetEdit"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:fontFamily="@font/plus_jakarta_sans_medium"
                            android:gravity="end|center_vertical"
                            android:includeFontPadding="false"
                            android:text="Edit"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvSisaBudget"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/roboto_bold"
                    android:text="Rp 3.000.000"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp" />

                <ProgressBar
                    android:id="@+id/progressBudget"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="16dp"
                    android:layout_marginTop="12dp"
                    android:indeterminate="false"
                    android:max="100"
                    android:progress="45"
                    android:progressDrawable="@drawable/budget_progress_bg" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="9dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvBudgetUsed"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/plus_jakarta_sans_medium"
                        android:text="Terpakai Rp 2.500.000"
                        android:textColor="#FFFFFF"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/tvBudgetTotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/plus_jakarta_sans_regular"
                        android:gravity="end"
                        android:text="dari Rp 3.000.000"
                        android:textColor="#FFFFFF"
                        android:textSize="10sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvBudgetPercentBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="21dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/budget_percent_badge_bg"
                    android:fontFamily="@font/plus_jakarta_sans_medium"
                    android:gravity="center"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:text="45,4% terpakai"
                    android:textColor="#262A24"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/tvInfoBudget"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="45% dari total budget sudah terpakai"
                    android:visibility="gone" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardBudgetStatus"
                android:layout_width="match_parent"
                android:layout_height="94dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="-24dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/pengeluaran_chart_card_bg"
                android:elevation="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <FrameLayout
                    android:id="@+id/budgetStatusIconContainer"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:background="@drawable/budget_status_icon_danger_bg">

                    <ImageView
                        android:id="@+id/ivBudgetStatusIcon"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_cancel_budget" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvBudgetStatusTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:fontFamily="@font/plus_jakarta_sans_semibold"
                        android:maxLines="1"
                        android:text="Pengeluaran melebihi budget"
                        android:textColor="#262A24"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvBudgetStatusDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/plus_jakarta_sans_regular"
                        android:lineSpacingExtra="1dp"
                        android:maxLines="2"
                        android:text="Kamu sudah melewati batas budget bulan ini. Tinjau pengeluaranmu."
                        android:textColor="#262A24"
                        android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardEditBudget"
                android:layout_width="match_parent"
                android:layout_height="236dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="18dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/pengeluaran_chart_card_bg"
                android:elevation="4dp"
                android:orientation="vertical"
                android:paddingStart="18dp"
                android:paddingTop="18dp"
                android:paddingEnd="18dp"
                android:paddingBottom="20dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/plus_jakarta_sans_semibold"
                    android:text="Edit Budget Perbulan"
                    android:textColor="#262A24"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/plus_jakarta_sans_regular"
                    android:text="Sesuaikan pengeluaran bulanan Kamu."
                    android:textColor="#8A8F83"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/etTargetBudget"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/input_note_bg"
                    android:fontFamily="@font/plus_jakarta_sans_medium"
                    android:hint="Rp 3.000.000"
                    android:inputType="number"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="#262A24"
                    android:textColorHint="#8A8F83"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnCancelEditBudget"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/input_button_cancel_bg"
                        android:backgroundTint="#EDEDE8"
                        android:fontFamily="@font/plus_jakarta_sans_semibold"
                        android:gravity="center"
                        android:includeFontPadding="true"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:paddingStart="0dp"
                        android:paddingTop="2dp"
                        android:paddingEnd="0dp"
                        android:paddingBottom="2dp"
                        android:text="Batal"
                        android:textAllCaps="false"
                        android:textColor="#262A24"
                        android:textSize="12sp"
                        app:backgroundTint="#EDEDE8" />

                    <Button
                        android:id="@+id/btnUpdateBudget"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/input_button_add_bg"
                        android:backgroundTint="#306D29"
                        android:fontFamily="@font/plus_jakarta_sans_semibold"
                        android:gravity="center"
                        android:includeFontPadding="true"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:paddingStart="0dp"
                        android:paddingTop="2dp"
                        android:paddingEnd="0dp"
                        android:paddingBottom="2dp"
                        android:text="Simpan"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        app:backgroundTint="#306D29" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/customBottomNav"
        android:layout_width="match_parent"
        android:layout_height="74dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_bottom_nav"
        android:elevation="8dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingTop="8dp"
        android:paddingEnd="10dp"
        android:paddingBottom="6dp">

        <LinearLayout
            android:id="@+id/navHomeButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_home_inactive" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:fontFamily="@font/plus_jakarta_sans_regular"
                android:text="Beranda"
                android:textColor="#262A24"
                android:textSize="9sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navPengeluaranButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.15"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_expenditure_inactive" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:fontFamily="@font/plus_jakarta_sans_regular"
                android:singleLine="true"
                android:text="Pengeluaran"
                android:textColor="#262A24"
                android:textSize="8sp" />
        </LinearLayout>

        <Space
            android:layout_width="74dp"
            android:layout_height="1dp" />

        <LinearLayout
            android:id="@+id/navBudgetButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_budget_active" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:fontFamily="@font/plus_jakarta_sans_medium"
                android:text="Budget"
                android:textColor="#306D29"
                android:textSize="9sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navRiwayatButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_history_inactive" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:fontFamily="@font/plus_jakarta_sans_regular"
                android:text="Riwayat"
                android:textColor="#262A24"
                android:textSize="9sp" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/fabAdd"
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="9dp"
        android:clickable="true"
        android:elevation="16dp"
        android:focusable="true"
        android:foreground="@drawable/fab_center_oval_ripple"
        android:translationZ="16dp">

        <FrameLayout
            android:layout_width="66dp"
            android:layout_height="66dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_center_input_button">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:scaleType="centerInside"
                android:src="@drawable/ic_input" />
        </FrameLayout>
    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
