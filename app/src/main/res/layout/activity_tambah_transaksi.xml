<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFDF7"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="24dp"
            android:paddingBottom="24dp">

            <RadioGroup
                android:id="@+id/radioGroupTipe"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/input_segment_bg"
                android:orientation="horizontal"
                android:padding="4dp">

                <RadioButton
                    android:id="@+id/radioPengeluaran"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/input_segment_option_bg"
                    android:button="@null"
                    android:checked="true"
                    android:fontFamily="@font/plus_jakarta_sans_semibold"
                    android:gravity="center"
                    android:text="Pengeluaran"
                    android:textColor="#306D29"
                    android:textSize="12sp" />

                <RadioButton
                    android:id="@+id/radioPemasukan"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/input_segment_option_bg"
                    android:button="@null"
                    android:fontFamily="@font/plus_jakarta_sans_medium"
                    android:gravity="center"
                    android:text="Pemasukan"
                    android:textColor="#262A24"
                    android:textSize="12sp" />
            </RadioGroup>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="36dp"
                android:fontFamily="@font/plus_jakarta_sans_medium"
                android:gravity="center"
                android:text="Jumlah"
                android:textColor="#262A24"
                android:textSize="10sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/roboto_bold"
                    android:text="Rp"
                    android:textColor="#306D29"
                    android:textSize="24sp" />

                <EditText
                    android:id="@+id/etNominal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/input_amount_bg"
                    android:fontFamily="@font/roboto_bold"
                    android:gravity="center"
                    android:hint="0"
                    android:inputType="numberDecimal"
                    android:minWidth="120dp"
                    android:padding="0dp"
                    android:singleLine="true"
                    android:textColor="#306D29"
                    android:textColorHint="#7CA877"
                    android:textSize="24sp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:fontFamily="@font/plus_jakarta_sans_medium"
                android:text="Tanggal"
                android:textColor="#262A24"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tvTanggal"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/input_date_pill_bg"
                android:clickable="true"
                android:drawableStart="@drawable/ic_calendar_input"
                android:drawablePadding="8dp"
                android:elevation="2dp"
                android:focusable="true"
                android:fontFamily="@font/plus_jakarta_sans_medium"
                android:gravity="center"
                android:minWidth="156dp"
                android:paddingStart="12dp"
                android:paddingEnd="14dp"
                android:text="Pilih Tanggal..."
                android:textColor="#262A24"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:fontFamily="@font/plus_jakarta_sans_medium"
                android:text="Kategori"
                android:textColor="#262A24"
                android:textSize="10sp" />

            <Spinner
                android:id="@+id/spKategori"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/input_spinner_bg"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:fontFamily="@font/plus_jakarta_sans_medium"
                android:text="Catatan"
                android:textColor="#262A24"
                android:textSize="10sp" />

            <EditText
                android:id="@+id/etCatatan"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/input_note_bg"
                android:fontFamily="@font/plus_jakarta_sans_regular"
                android:hint="Tambah catatan"
                android:inputType="text"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:singleLine="true"
                android:textColor="#262A24"
                android:textColorHint="#8A8F83"
                android:textSize="12sp" />

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="24dp"
        android:paddingTop="8dp">

        <Button
            android:id="@+id/btnBatal"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:background="@drawable/input_button_cancel_bg"
            android:backgroundTint="@null"
            android:fontFamily="@font/plus_jakarta_sans_semibold"
            android:text="Batal"
            android:textAllCaps="false"
            android:textColor="#262A24"
            android:textSize="14sp" />

        <Space
            android:layout_width="16dp"
            android:layout_height="1dp" />

        <Button
            android:id="@+id/btnSimpan"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:background="@drawable/input_button_add_bg"
            android:backgroundTint="@null"
            android:fontFamily="@font/plus_jakarta_sans_semibold"
            android:text="Tambahkan"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />
    </LinearLayout>

</LinearLayout>
